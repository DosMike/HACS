{
  "name": "@dosmike/hacs",
  "version": "1.1.2",
  "description": "Hierarchical Authorization Capability System for TypeScript and React.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "packageManager": "npm@12.0.0-pre.0.0+sha512.42a81f7586d8cc6530fd5360eef4c2e6e99132bf5cd46750b7c4388706fd134c5c3a7fa7a6c94bb081d448ca67381914b65ed2e4ce2afb69f70bf0dcba893be5",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DosMike/HACS.git",
    "directory": "nodejs"
  },
  "bugs": {
    "url": "https://github.com/DosMike/HACS/issues"
  },
  "homepage": "https://github.com/DosMike/HACS/tree/main/nodejs"
}
